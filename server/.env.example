PORT=3000
MONGODB_URI=mongodb://localhost:27017/igniup
JWT_SECRET=your-super-secret-key-change-in-production

# --- Achievement emails (when user earns a new badge) ---
# Option A: Use test inbox (no real email) — add to .env:
#   MAIL_USE_ETHEREAL=true
# Then restart server; when you earn a badge, the server console will print a "Preview" URL — open it to see the email.
# Option B: Real email — set SMTP (e.g. Gmail with App Password):
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USER=your@gmail.com
#   MAIL_PASS=your-app-password
#   MAIL_FROM=igniUp <your@gmail.com>
